# LoreHub environment configuration.
# Copy to .env and adjust. Compose reads this file automatically.

# --- Database ---
DATABASE_URL=postgres://postgres:postgres@localhost:5432/lorehub

# --- Lore transport ---
# The API talks to a real loreserver over gRPC. Start one (zero-config) with
# `loreserver`, or via `docker compose --profile lore up`.
LORE_SERVER_URL=http://127.0.0.1:41337
# Optional override for the lore-server image used by the "lore" compose profile.
# LORE_SERVER_IMAGE=ghcr.io/epicgames/lore-server:latest

# --- Auth / JWT ---
# Change this in any non-local environment.
LORE_JWT_SECRET=local-development-secret-change-me
LORE_JWT_ISSUER=lorehub-api

# --- Worker ---
REDIS_URL=redis://localhost:6379

# --- API ---
PORT=8080

# --- Web ---
# Base URL the web app uses to reach the API (browser-visible).
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080
